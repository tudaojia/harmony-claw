{
  "app": {
    "signingConfigs": [],
    "compileSdkVersion": 10,
    "compatibleSdkVersion": 10,
    "products": [
      {
        "name": "default",
        "compileSdkVersion": 10,
        "compatibleSdkVersion": 10,
        "runtimeOS": "HarmonyOS"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [{ "name": "default", "applyToProducts": ["default"] }]
    },
    {
      "name": "terminal",
      "srcPath": "./terminal",
      "targets": [{ "name": "default", "applyToProducts": ["default"] }]
    },
    {
      "name": "bootstrap",
      "srcPath": "./bootstrap",
      "targets": [{ "name": "default", "applyToProducts": ["default"] }]
    }
  ]
}
